# Runtime
NODE_ENV=development
LOG_LEVEL=info

# Service ports
WEB_PORT=3000
API_PORT=4000

# Workspace bootstrap for smoke scenarios
WORKSPACE_NAME=demo-workspace
DEFAULT_REPO_URL=https://github.com/example/repo
SMOKE_CHAT_INTENT=Fix failing tests and prepare a draft PR
APPROVER_HANDLE=@operator

# Worker/runtime controls
WORKER_CONCURRENCY=2
TASK_POLL_INTERVAL_MS=1500

# Data plane
DATABASE_URL=postgresql://postgres:postgres@db:5432/swarm
REDIS_URL=redis://redis:6379

# GitHub integration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OWNER=example-org
GITHUB_REPO=example-repo

# Codex provider integration
CODEX_MODE=dry-run
CODEX_CLI_PATH=codex
CODEX_SESSION_STRATEGY=cli-reuse

# Telegram integration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Governance / audit
AUDIT_RETENTION_DAYS=90
POLICY_REQUIRE_HUMAN_APPROVAL=true
PUBLISH_DRY_RUN=true
