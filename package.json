{
  "name": "codex-github-swarm",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "install": "pnpm install --ignore-scripts",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "smoke": "pnpm run build && pnpm run test",
    "seed/demo": "pnpm --filter @swarm/api run seed:demo"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.29.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.15.3"
  }
}
