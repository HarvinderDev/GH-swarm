{
  "name": "codex-github-swarm",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted dashboard-first conversational AI engineering manager for GitHub repositories.",
  "scripts": {
    "lint": "node scripts/lint-check.mjs",
    "typecheck": "node scripts/typecheck-check.mjs",
    "test": "node scripts/test-check.mjs",
    "build": "node scripts/build-check.mjs",
    "smoke": "bash scripts/smoke-all.sh",
