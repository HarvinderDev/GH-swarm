{
  "name": "@swarm/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke": "tsx src/smoke.ts",
    "seed:demo": "tsx src/seed.ts"
  },
  "dependencies": {
    "@swarm/domain": "workspace:*",
    "@swarm/orchestrator": "workspace:*",
    "@swarm/provider-codex": "workspace:*",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
